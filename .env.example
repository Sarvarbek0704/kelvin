# =============================================================================
#  KELVIN — muhit o'zgaruvchilari SHABLONI
#
#  ⚠️  BU FAYL SHABLON. HAQIQIY QIYMAT YOZILMAYDI.
#
#  Ishlatish:  cp .env.example .env  →  keyin .env ni to'ldiring
#  .env FAYLI HECH QACHON COMMIT QILINMAYDI (.gitignore da).
#
#  Nega bu shuncha ta'kidlanadi: loyiha egasining oldingi loyihalarida
#  DB parollari, JWT kalitlari va hatto server IP manzili GitHub'ga
#  commit qilingan edi. docs/11-security.md §9
#
#  Prod'da .env ishlatilmaydi — sirlar Vault/Doppler'dan.
# =============================================================================

# --- Ilova ---------------------------------------------------------------
NODE_ENV=development
PORT=3000
API_PREFIX=api
CORS_ORIGINS=http://localhost:5173,http://localhost:5174

# --- Ma'lumotlar bazasi --------------------------------------------------
DATABASE_URL=postgresql://kelvin:CHANGE_ME@localhost:5432/kelvin?schema=public

# --- Redis ---------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# --- Meilisearch (docs/05-catalog-and-search.md) -------------------------
MEILISEARCH_HOST=http://localhost:7700
MEILISEARCH_API_KEY=

# --- JWT -----------------------------------------------------------------
# Generatsiya:  openssl rand -base64 64
# ⚠️  ACCESS va REFRESH kalitlari FARQ qilishi SHART.
#     Har muhit uchun alohida kalit. Dev kaliti prod'da ishlatilmaydi.
JWT_ACCESS_SECRET=CHANGE_ME_openssl_rand_base64_64
JWT_REFRESH_SECRET=CHANGE_ME_DIFFERENT_FROM_ACCESS
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# --- Argon2id (docs/adr/0002-argon2id-over-bcrypt.md) --------------------
# ⚠️  TAXMINIY qiymatlar. Prod hardware'da benchmark kerak — maqsad ~50-100ms.
ARGON2_MEMORY_COST=19456
ARGON2_TIME_COST=2
ARGON2_PARALLELISM=1

# --- Rezerv (docs/06-inventory-and-reservations.md §3) -------------------
# ⚠️  TAXMINIY. Juda qisqa → mijoz checkout'ni tugatolmaydi.
#     Juda uzun → tovar bekorga bloklanadi.
RESERVATION_TTL_SECONDS=900

# --- Object storage (S3-mos) ---------------------------------------------
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=kelvin-dev
S3_ACCESS_KEY=CHANGE_ME
S3_SECRET_KEY=CHANGE_ME
S3_FORCE_PATH_STYLE=true

# --- To'lov provayderlari ------------------------------------------------
# ⚠️  Bu integratsiyalar hali IMPLEMENTATSIYA QILINMAGAN.
#     API detallari rasmiy hujjatdan tekshirilishi kerak:
#       docs.click.uz / developer.help.paycom.uz
#     docs/08-payments-and-installments.md
CLICK_MERCHANT_ID=
CLICK_SERVICE_ID=
CLICK_SECRET_KEY=
CLICK_MERCHANT_USER_ID=

PAYME_MERCHANT_ID=
PAYME_SECRET_KEY=
PAYME_TEST_MODE=true

UZUM_MERCHANT_ID=
UZUM_SECRET_KEY=

# --- Rassrochka ----------------------------------------------------------
# ⚠️  YURIDIK BLOKER: do'konning o'z rassrochkasi litsenziya talab qiladimi?
#     Yurist tasdig'isiz bu modul prod'ga chiqmaydi.
#     docs/08-payments-and-installments.md §3
INSTALLMENT_PROVIDER=
INSTALLMENT_PROVIDER_KEY=

# --- Xabarnomalar --------------------------------------------------------
# Eskiz.uz — O'zbekistonda SMS
ESKIZ_EMAIL=
ESKIZ_PASSWORD=
ESKIZ_FROM=4546

TELEGRAM_BOT_TOKEN=

SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@kelvin.uz

# --- Kuzatuv -------------------------------------------------------------
LOG_LEVEL=debug
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
SENTRY_DSN=

# --- Rate limiting (docs/04-api-spec.md §8) ------------------------------
THROTTLE_TTL=60
THROTTLE_LIMIT=300

# --- Storefront (Vite — VITE_ prefiksi majburiy) -------------------------
VITE_API_URL=http://localhost:3000/api/v1

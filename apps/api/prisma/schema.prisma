/// Vaqt oralig'i. ⚠️ Slot band qilishda ham RACE CONDITION bor —
/// stock rezervi bilan bir xil muammo. docs/09 §2
model DeliverySlot {
  id     String @id @default(uuid(7)) @db.Uuid
  zoneId String @map("zone_id") @db.Uuid

  date      DateTime @db.Date
  startTime String   @map("start_time") // "09:00"
  endTime   String   @map("end_time")   // "12:00"

  capacity Int
  booked   Int @default(0)

  isActive Boolean @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  zone      DeliveryZone @relation(fields: [zoneId], references: [id], onDelete: Cascade)
  shipments Shipment[]

  @@unique([zoneId, date, startTime])
  @@index([date, isActive])
  @@map("delivery_slots")
}

model Courier {
  id     String @id @default(uuid(7)) @db.Uuid
  userId String @unique @map("user_id") @db.Uuid

  fullName String @map("full_name")
  phone    String

  vehicleType   String? @map("vehicle_type")
  vehicleNumber String? @map("vehicle_number")

  isActive Boolean @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  shipments Shipment[]

  @@map("couriers")
}

model Shipment {
  id      String @id @default(uuid(7)) @db.Uuid
  orderId String @map("order_id") @db.Uuid

  addressId String  @map("address_id") @db.Uuid
  slotId    String? @map("slot_id") @db.Uuid
  courierId String? @map("courier_id") @db.Uuid

  status ShipmentStatus @default(PENDING)

  trackingNumber String? @map("trackingnumber")

  /// Mo'rt tovar — qadoqlash belgisi. docs/09 §3
  isFragile Boolean @default(false) @map("is_fragile")

  shippedAt   DateTime? @map("shipped_at") @db.Timestamptz(3)
  deliveredAt DateTime? @map("delivered_at") @db.Timestamptz(3)
  failureReason String? @map("failure_reason")
  /// Yetkazishda sinib qolsa — dalil
  proofPhotoUrl String? @map("proof_photo_url")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  order   Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  address Address       @relation(fields: [addressId], references: [id], onDelete: Restrict)
  slot    DeliverySlot? @relation(fields: [slotId], references: [id], onDelete: SetNull)
  courier Courier?      @relation(fields: [courierId], references: [id], onDelete: SetNull)

  @@index([orderId])
  @@index([courierId, status])
  @@index([status])
  @@map("shipments")
}

/// Qandil o'rnatish — elektrik kerak. Upsell.
model InstallationJob {
  id      String @id @default(uuid(7)) @db.Uuid
  orderId String @map("order_id") @db.Uuid

  installerUserId String? @map("installer_user_id") @db.Uuid
  status          InstallationStatus @default(REQUESTED)

  scheduledAt DateTime? @map("scheduled_at") @db.Timestamptz(3)
  completedAt DateTime? @map("completed_at") @db.Timestamptz(3)

  /// TIYINDA. Murakkablikka bog'liq (baland shift, ko'p shoxli qandil)
  priceAmount BigInt @map("price_amount")
  currency    String @default("UZS")

  note String?

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([installerUserId, status])
  @@map("installation_jobs")
}

// ============================================================================
//  POS — offline kassa. docs/10-crm-pos-analytics.md §2
//  ⚠️ Onlayn va offline sotuv BIR XIL Order va ledger'ga tushadi.
// ============================================================================

model PosShift {
  id     String @id @default(uuid(7)) @db.Uuid
  userId String @map("user_id") @db.Uuid

  status PosShiftStatus @default(OPEN)

  /// TIYINDA
  openingCashAmount BigInt  @map("opening_cash_amount")
  closingCashAmount BigInt? @map("closing_cash_amount")
  /// Hisoblangan vs haqiqiy farq
  cashDifferenceAmount BigInt? @map("cash_difference_amount")
  currency String @default("UZS")

  openedAt DateTime  @default(now()) @map("opened_at") @db.Timestamptz(3)
  closedAt DateTime? @map("closed_at") @db.Timestamptz(3)

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  user User @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@index([userId, status])
  @@map("pos_shifts")
}

// ============================================================================
//  CONTENT / REVIEW
// ============================================================================

model Review {
  id         String @id @default(uuid(7)) @db.Uuid
  productId  String @map("product_id") @db.Uuid
  customerId String @map("customer_id") @db.Uuid

  rating Int
  title  String?
  body   String

  /// Faqat sotib olgan mijoz sharh qoldira oladimi
  isVerifiedPurchase Boolean @default(false) @map("is_verified_purchase")

  status ReviewStatus @default(PENDING_MODERATION)
  moderatedBy String?  @map("moderated_by") @db.Uuid

  photoUrls String[] @map("photo_urls")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@unique([productId, customerId])
  @@index([productId, status])
  @@map("reviews")
}

model Question {
  id         String @id @default(uuid(7)) @db.Uuid
  productId  String @map("product_id") @db.Uuid
  customerId String @map("customer_id") @db.Uuid

  body   String
  status ReviewStatus @default(PENDING_MODERATION)

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  answers  Answer[]

  @@index([productId, status])
  @@map("questions")
}

model Answer {
  id         String @id @default(uuid(7)) @db.Uuid
  questionId String @map("question_id") @db.Uuid

  body        String
  authorUserId String @map("author_user_id") @db.Uuid
  /// Do'kon rasmiy javobimi
  isOfficial  Boolean @default(false) @map("is_official")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([questionId])
  @@map("answers")
}

model BlogPost {
  id   String @id @default(uuid(7)) @db.Uuid
  slug String @unique

  title   Json
  excerpt Json?
  body    Json

  coverUrl String? @map("cover_url")

  metaTitle       Json? @map("meta_title")
  metaDescription Json? @map("meta_description")

  isPublished Boolean   @default(false) @map("is_published")
  publishedAt DateTime? @map("published_at") @db.Timestamptz(3)
  authorUserId String?  @map("author_user_id") @db.Uuid

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  @@index([isPublished, publishedAt])
  @@map("blog_posts")
}

/// Statik sahifalar: О компании, Возврат, Гарантии, Доставка и оплата
model Page {
  id   String @id @default(uuid(7)) @db.Uuid
  slug String @unique

  title Json
  body  Json

  metaTitle       Json? @map("meta_title")
  metaDescription Json? @map("meta_description")

  isPublished Boolean @default(true) @map("is_published")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  @@map("pages")
}

// ============================================================================
//  ADMIN / INFRA
// ============================================================================

/// IMMUTABLE, append-only. DB trigger + REVOKE bilan majburlanadi.
///
/// Nima yoziladi: narx o'zgarishi, chegirma, qoldiq tuzatish, buyurtma
/// bekor qilish, rol berish, refund, POS smena.
/// Nega: ICHKI o'g'irlik (sotuvchi o'ziga chegirma qiladi) va nizolar.
/// docs/11-security.md §11
model AuditLog {
  id String @id @default(uuid(7)) @db.Uuid

  actorUserId String? @map("actor_user_id") @db.Uuid

  action       String
  resourceType String  @map("resource_type")
  resourceId   String? @map("resource_id") @db.Uuid

  before Json?
  after  Json?

  ipAddress String? @map("ip_address")
  userAgent String? @map("user_agent")
  traceId   String? @map("trace_id")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  actor User? @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([actorUserId, createdAt])
  @@index([resourceType, resourceId])
  @@index([action, createdAt])
  @@map("audit_logs")
}

model Notification {
  id String @id @default(uuid(7)) @db.Uuid

  /// SMS | TELEGRAM | EMAIL | PUSH
  channel   String
  recipient String

  /// i18n kaliti — matn emas
  templateKey String @map("template_key")
  payload     Json

  sentAt        DateTime? @map("sent_at") @db.Timestamptz(3)
  failedAt      DateTime? @map("failed_at") @db.Timestamptz(3)
  failureReason String?   @map("failure_reason")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  @@index([channel, sentAt])
  @@map("notifications")
}

/// Transactional outbox — dual write problem yechimi.
/// Kritik event'lar (to'lov, buyurtma, qoldiq) DB tranzaksiyasi ICHIDA
/// shu jadvalga yoziladi. Alohida worker publish qiladi.
/// Kafolat: at-least-once → HAR handler idempotent bo'lishi SHART.
model OutboxEvent {
  id String @id @default(uuid(7)) @db.Uuid

  eventType     String @map("event_type")
  aggregateType String @map("aggregate_type")
  aggregateId   String @map("aggregate_id") @db.Uuid
  payload       Json

  status    OutboxStatus @default(PENDING)
  attempts  Int          @default(0)
  lastError String?      @map("last_error")

  availableAt DateTime  @default(now()) @map("available_at") @db.Timestamptz(3)
  publishedAt DateTime? @map("published_at") @db.Timestamptz(3)

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  @@index([status, availableAt])
  @@index([aggregateType, aggregateId])
  @@map("outbox_events")
}

model FeatureFlag {
  id  String @id @default(uuid(7)) @db.Uuid
  key String @unique

  isEnabled         Boolean @default(false) @map("is_enabled")
  rolloutPercentage Int     @default(0) @map("rollout_percentage")

  description String?

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  @@map("feature_flags")
}

/// API idempotentlik. `Idempotency-Key` header'i bo'yicha birinchi javob
/// saqlanadi; takroriy so'rov shu javobni oladi va operatsiya QAYTA
/// BAJARILMAYDI.
///
/// MAJBURIY: to'lov, buyurtma yaratish, rezerv, stock harakati.
/// docs/04-api-spec.md §7
model IdempotencyRecord {
  id  String @id @default(uuid(7)) @db.Uuid
  key String @unique

  /// Qaysi endpoint uchun — bir xil kalit boshqa endpoint'da ishlatilmasin
  endpoint String
  /// So'rov body'sining hash'i. Bir xil kalit, boshqa body → 422 konflikt.
  requestHash String @map("request_hash")

  /// Birinchi javob — takroriy so'rovga aynan shu qaytariladi
  responseStatus Int?  @map("response_status")
  responseBody   Json? @map("response_body")

  /// IN_PROGRESS | COMPLETED | FAILED
  status String @default("IN_PROGRESS")

  expiresAt DateTime @map("expires_at") @db.Timestamptz(3)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  @@index([expiresAt])
  @@map("idempotency_records")
}

/// Saga holati — buyurtma oqimi to'lov ↔ rezerv ↔ yetkazib berishga tegadi.
/// Distributed tranzaksiya YO'Q → orchestration saga + kompensatsiya.
///
/// ⚠️ "To'lov o'tdi, lekin tovar qolmadi" holati AVTOMATIK refund qilinmaydi
///    → `manual_review`. Sabab: docs/07-order-and-checkout.md §3
model SagaState {
  id String @id @default(uuid(7)) @db.Uuid

  /// ORDER_CHECKOUT | ORDER_CANCEL | ORDER_RETURN
  sagaType    String @map("saga_type")
  aggregateId String @map("aggregate_id") @db.Uuid

  /// RUNNING | COMPLETED | COMPENSATING | COMPENSATED | MANUAL_REVIEW
  status      String @default("RUNNING")
  currentStep String @map("current_step")

  /// Bajarilgan qadamlar — kompensatsiya teskari tartibda yuradi
  completedSteps Json @default("[]") @map("completed_steps")
  /// Qadamlar orasidagi kontekst
  context Json @default("{}")

  lastError String? @map("last_error")
  attempts  Int     @default(0)

  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)
  completedAt DateTime? @map("completed_at") @db.Timestamptz(3)

  @@unique([sagaType, aggregateId])
  @@index([status])
  @@map("saga_states")
}

/// Inventarizatsiya qatori — qo'lda hisoblash natijasi.
/// Farq (surplus/shortage) → tuzatish harakati (StockMovement.ADJUSTMENT).
/// Kim tasdiqlaydi — audit. docs/06-inventory-and-reservations.md §5
model InventoryLine {
  id String @id @default(uuid(7)) @db.Uuid

  warehouseId String @map("warehouse_id") @db.Uuid
  variantId   String @map("variant_id") @db.Uuid

  /// Tizim bo'yicha kutilgan
  expectedQuantity Int @map("expected_quantity")
  /// Qo'lda hisoblangan
  countedQuantity  Int @map("counted_quantity")
  /// counted - expected. Manfiy = kamomad (ehtimol o'g'irlik → audit)
  differenceQuantity Int @map("difference_quantity")

  countedBy   String    @map("counted_by") @db.Uuid
  approvedBy  String?   @map("approved_by") @db.Uuid
  approvedAt  DateTime? @map("approved_at") @db.Timestamptz(3)

  note String?

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  @@index([warehouseId, createdAt])
  @@index([variantId])
  @@map("inventory_lines")
}

/// Ta'minotchiga da'vo — mo'rt tovar (shisha qandil) singan holda keldi.
/// docs/06-inventory-and-reservations.md §7
model SupplierClaim {
  id String @id @default(uuid(7)) @db.Uuid

  supplierId      String  @map("supplier_id") @db.Uuid
  purchaseOrderId String? @map("purchase_order_id") @db.Uuid
  variantId       String  @map("variant_id") @db.Uuid

  quantity Int
  /// DAMAGED | MISSING | WRONG_ITEM | QUALITY
  reason   String

  /// TIYINDA — da'vo summasi
  claimAmount BigInt @map("claim_amount")
  currency    String @default("UZS")

  /// Dalil — singan tovar fotosi
  photoUrls String[] @map("photo_urls")

  /// OPEN | SUBMITTED | ACCEPTED | REJECTED | SETTLED
  status String @default("OPEN")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  @@index([supplierId, status])
  @@index([purchaseOrderId])
  @@map("supplier_claims")
}

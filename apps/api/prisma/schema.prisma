  @@index([orderId, createdAt])
  @@map("order_status_history")
}

// ============================================================================
//  INVENTORY — docs/06-inventory-and-reservations.md
//  ⚠️ Bu loyihaning ENG NOZIK qismi: oversell / race condition
// ============================================================================

model Warehouse {
  id   String @id @default(uuid(7)) @db.Uuid
  code String @unique
  name Json

  /// MAIN | SHOWROOM | TRANSIT
  kind String @default("MAIN")

  address String?
  /// Mijozga ko'rinadigan qoldiqqa hisoblanadimi
  isSellable Boolean @default(true) @map("is_sellable")
  isActive   Boolean @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  stockItems     StockItem[]
  movements      StockMovement[]
  reservations   StockReservation[]
  purchaseOrders PurchaseOrder[]

  @@map("warehouses")
}

/// Variant × ombor → qoldiq.
///
/// ⚠️ `onHand` va `reserved` FAQAT atomik UPDATE bilan o'zgaradi:
///    UPDATE stock_items SET reserved = reserved + $1
///    WHERE id = $2 AND (on_hand - reserved) >= $1
///    RETURNING *
///
///    Qator qaytmasa → yetarli qoldiq yo'q. Bu oversell'ning oldini oladi
///    hech qanday qulfsiz. docs/06-inventory-and-reservations.md §2
///
/// `version` — optimistic lock uchun zaxira.
model StockItem {
  id          String @id @default(uuid(7)) @db.Uuid
  variantId   String @map("variant_id") @db.Uuid
  warehouseId String @map("warehouse_id") @db.Uuid

  /// Jismonan omborda
  onHand   Int @default(0) @map("on_hand")
  /// Band qilingan (savat/buyurtma)
  reserved Int @default(0)
  /// available = onHand - reserved (hisoblanadi, saqlanmaydi)

  /// Qayta buyurtma chegarasi
  reorderPoint    Int? @map("reorder_point")
  reorderQuantity Int? @map("reorder_quantity")

  version Int @default(0)

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  variant   ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  warehouse Warehouse      @relation(fields: [warehouseId], references: [id], onDelete: Restrict)

  @@unique([variantId, warehouseId])
  @@index([warehouseId])
  @@map("stock_items")
}

/// Har harakat — IMMUTABLE jurnal. `onHand` ni to'g'ridan-to'g'ri
/// o'zgartirish TAQIQLANADI; har o'zgarish shu yerda iz qoldiradi.
///
/// Invariant: SUM(movements.quantity) == stock_items.on_hand
/// Bu property test bilan tekshiriladi.
model StockMovement {
  id          String @id @default(uuid(7)) @db.Uuid
  variantId   String @map("variant_id") @db.Uuid
  warehouseId String @map("warehouse_id") @db.Uuid

  type StockMovementType
  /// Musbat = kirim, manfiy = chiqim
  quantity Int

  /// Manba: order_id, purchase_order_id, inventory_count_id...
  referenceType String? @map("reference_type")
  referenceId   String? @map("reference_id") @db.Uuid

  actorUserId String? @map("actor_user_id") @db.Uuid
  note        String?

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  variant   ProductVariant @relation(fields: [variantId], references: [id], onDelete: Restrict)
  warehouse Warehouse      @relation(fields: [warehouseId], references: [id], onDelete: Restrict)

  @@index([variantId, createdAt])
  @@index([warehouseId, createdAt])
  @@index([referenceType, referenceId])
  @@map("stock_movements")
}

/// Rezerv. TTL bilan — checkout tashlab ketilsa avtomatik bo'shaydi.
/// docs/06-inventory-and-reservations.md §3
model StockReservation {
  id          String @id @default(uuid(7)) @db.Uuid
  variantId   String @map("variant_id") @db.Uuid
  warehouseId String @map("warehouse_id") @db.Uuid
  orderId     String? @map("order_id") @db.Uuid
  cartId      String? @map("cart_id") @db.Uuid

  quantity Int
  status   ReservationStatus @default(PENDING)

  /// Muddati tugagach bo'shatiladi
  expiresAt  DateTime  @map("expires_at") @db.Timestamptz(3)
  releasedAt DateTime? @map("released_at") @db.Timestamptz(3)
  consumedAt DateTime? @map("consumed_at") @db.Timestamptz(3)

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  variant   ProductVariant @relation(fields: [variantId], references: [id], onDelete: Restrict)
  warehouse Warehouse      @relation(fields: [warehouseId], references: [id], onDelete: Restrict)
  order     Order?         @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([status, expiresAt])
  @@index([orderId])
  @@index([variantId])
  @@map("stock_reservations")
}


// ============================================================================
//  PAYMENT — docs/08-payments-and-installments.md
//  ⚠️ Pul: BigInt TIYINDA. Float HECH QACHON.
// ============================================================================

model Payment {
  id      String @id @default(uuid(7)) @db.Uuid
  orderId String @map("order_id") @db.Uuid

  provider PaymentProvider
  status   PaymentStatus   @default(CREATED)

  amount   BigInt
  currency String @default("UZS")

  providerTransactionId String? @map("provider_transaction_id")
  /// Provayderdan kelgan xom javob — nizoda dalil
  providerPayload       Json?   @map("provider_payload")

  /// Webhook ikki marta kelsa himoya. docs/08 §4
  idempotencyKey String @unique @map("idempotency_key")

  failureReason String?   @map("failure_reason")
  paidAt        DateTime? @map("paid_at") @db.Timestamptz(3)

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  order Order @relation(fields: [orderId], references: [id], onDelete: Restrict)

  refunds       Refund[]
  ledgerEntries LedgerEntry[]

  @@unique([provider, providerTransactionId])
  @@index([orderId])
  @@index([status])
  @@map("payments")
}

model Refund {
  id        String @id @default(uuid(7)) @db.Uuid
  paymentId String @map("payment_id") @db.Uuid

  amount   BigInt
  currency String @default("UZS")

  reason String
  status PaymentStatus @default(CREATED)

  providerRefundId String? @map("provider_refund_id")
  idempotencyKey   String  @unique @map("idempotency_key")

  refundedAt DateTime? @map("refunded_at") @db.Timestamptz(3)

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  payment Payment @relation(fields: [paymentId], references: [id], onDelete: Restrict)

  @@index([paymentId])
  @@map("refunds")
}

/// RASSROCHKA — O'zbekistonda qimmat tovar shu bilan sotiladi.
///
/// ⚠️ YURIDIK BLOKER: do'konning O'Z rassrochkasi kredit berish hisoblanadimi
///    va litsenziya talab qiladimi? Yurist tasdig'i kerak.
///    docs/08-payments-and-installments.md §3
model InstallmentPlan {
  id      String @id @unique @default(uuid(7)) @db.Uuid
  orderId String @unique @map("order_id") @db.Uuid

  /// OWN (do'kon o'zi) | PROVIDER (Uzum Nasiya, Alif...)
  kind     String
  provider String?

  /// TIYINDA
  principalAmount BigInt @map("principal_amount")
  /// Boshlang'ich badal
  downPaymentAmount BigInt @default(0) @map("down_payment_amount")
  /// Umumiy to'lanadigan (foiz bilan)
  totalPayableAmount BigInt @map("total_payable_amount")
  currency String @default("UZS")

  /// Basis point (1200 = 12%)
  interestRateBp Int @default(0) @map("interest_rate_bp")
  termMonths     Int @map("term_months")

  status InstallmentStatus @default(PENDING)

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  order    Order                 @relation(fields: [orderId], references: [id], onDelete: Restrict)
  schedule InstallmentSchedule[]

  @@map("installment_plans")
}

/// To'lov grafigi.
///
/// ⚠️ PUL MATEMATIKASI: 5 000 000 so'mni 3 oyga bo'lsak — 1 666 666.67.
///    Tiyin yo'qolmasligi kerak: SUM(schedule.amount) == totalPayableAmount.
///    `Money.allocate()` ishlatiladi. Property test bilan tekshiriladi.
model InstallmentSchedule {
  id     String @id @default(uuid(7)) @db.Uuid
  planId String @map("plan_id") @db.Uuid

  installmentNumber Int      @map("installment_number")
  dueDate           DateTime @map("due_date") @db.Date

  amount     BigInt
  paidAmount BigInt @default(0) @map("paid_amount")
  /// Kechikish penyasi
  penaltyAmount BigInt @default(0) @map("penalty_amount")
  currency   String @default("UZS")

  status InstallmentStatus @default(PENDING)
  paidAt DateTime?         @map("paid_at") @db.Timestamptz(3)

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  plan InstallmentPlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@unique([planId, installmentNumber])
  @@index([status, dueDate])
  @@map("installment_schedules")
}

/// Double-entry ledger. Oddiy `balance` ustuni YETARLI EMAS.
/// Invariant: SUM(debit) == SUM(credit) har `transactionId` uchun.
/// APPEND-ONLY: xato bo'lsa teskari yozuv, o'chirish emas.
/// docs/08-payments-and-installments.md §7
model LedgerEntry {
  id String @id @default(uuid(7)) @db.Uuid

  /// Bitta tranzaksiyaning yozuvlari bir xil transactionId ga ega
  transactionId String @map("transaction_id") @db.Uuid

  paymentId String? @map("payment_id") @db.Uuid

  /// "cash.click" | "cash.register" | "revenue.product" |
  /// "liability.installment_receivable" | "expense.refund"
  account   String
  direction LedgerDirection
  amount    BigInt
  currency  String @default("UZS")

  description String?

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  payment Payment? @relation(fields: [paymentId], references: [id], onDelete: SetNull)

  @@index([transactionId])
  @@index([account, createdAt])
  @@map("ledger_entries")
}

// ============================================================================

// ============================================================================
//  KELVIN — Ma'lumotlar modeli
//  Yoritish texnikasi do'koni. Spetsifikatsiya: docs/03-data-model.md
//
//  KONVENSIYALAR:
//   - Prisma model: PascalCase, BIRLIK   → DB jadval: snake_case, KO'PLIK
//   - PK: UUID v7 (vaqt bo'yicha tartiblanadi → index fragmentatsiyasi yo'q)
//     ⚠️ @default(uuid(7)) Prisma >= 5.14 talab qiladi
//   - Pul: BigInt, TIYINDA. Float HECH QACHON. + alohida currency ustuni
//   - Vaqt: DateTime @db.Timestamptz(3), UTC
//   - Soft delete: deleted_at (faqat muhim entity'larda)
//
//  ⚠️ Bu BITTA do'kon uchun (single-tenant). Multi-tenant EMAS.
// ============================================================================

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions", "relationJoins"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [pgcrypto, pg_trgm, btree_gin]
}

// ============================================================================
//  ENUM'lar
// ============================================================================

enum UserStatus {
  PENDING_VERIFICATION
  ACTIVE
  SUSPENDED
  BANNED
}

/// docs/01-product-spec.md §4 — RBAC matritsasi
enum Role {
  OWNER
  ADMIN
  CONTENT_MANAGER
  SALES
  WAREHOUSE
  COURIER
  INSTALLER
  ACCOUNTANT
  CUSTOMER
}

/// Yoritgichga xos atribut tiplari — docs/05-catalog-and-search.md §2
enum AttributeType {
  /// Aniq qiymatlar ro'yxati (rang harorati: 2700/3000/4000/5000/6500)
  ENUM
  /// Son + diapazon filtri (lyumen, vatt)
  NUMBER
  /// Ha/yo'q (dimmable, bulbs_included)
  BOOLEAN
  /// Erkin matn
  TEXT
  /// Ierarxik — IP65 IP44 talabini ham qanoatlantiradi
  ORDINAL
}

enum ProductStatus {
  DRAFT
  ACTIVE
  ARCHIVED
  OUT_OF_PRODUCTION
}

/// docs/07-order-and-checkout.md §2
enum OrderStatus {
  DRAFT
  PENDING_PAYMENT
  PAYMENT_FAILED
  PAID
  CONFIRMED
  PICKING
  PACKED
  SHIPPED
  DELIVERED
  COMPLETED
  CANCELLED
  RETURNED
  PARTIALLY_RETURNED
}

enum OrderChannel {
  ONLINE
  POS
  PHONE
  TELEGRAM
}

/// docs/06-inventory-and-reservations.md §3
enum ReservationStatus {
  PENDING
  CONFIRMED
  CONSUMED
  RELEASED
  EXPIRED
}

/// Har harakat immutable jurnalga yoziladi. `quantity` ustunini
/// to'g'ridan-to'g'ri o'zgartirish TAQIQLANADI — docs/06 §1
enum StockMovementType {
  PURCHASE_RECEIPT
  SALE
  RETURN
  TRANSFER_IN
  TRANSFER_OUT
  ADJUSTMENT
  DAMAGE
  INVENTORY_COUNT
}

enum PaymentStatus {
  CREATED
  PENDING
  PAID
  FAILED
  EXPIRED
  CANCELLED
  REFUND_REQUESTED
  REFUNDED
  PARTIALLY_REFUNDED
}

enum PaymentProvider {
  CLICK
  PAYME
  UZUM
  CASH
  BANK_TRANSFER
  INSTALLMENT_PROVIDER
}

/// Rassrochka — O'zbekistonda qimmat tovar shu bilan sotiladi.
/// ⚠️ Yuridik bloker: o'z rassrochkasi litsenziya talab qiladimi?
/// docs/08-payments-and-installments.md §3
enum InstallmentStatus {
  PENDING
  PAID
  OVERDUE
  DEFAULTED
  CANCELLED
}

enum LedgerDirection {
  DEBIT
  CREDIT
}

enum ShipmentStatus {
  PENDING
  ASSIGNED
  IN_TRANSIT
  DELIVERED
  FAILED
  RETURNED
}

enum InstallationStatus {
  REQUESTED
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  PROPOSAL
  WON
  LOST
}

enum PosShiftStatus {
  OPEN
  CLOSED
}

enum ReviewStatus {
  PENDING_MODERATION
  APPROVED
  REJECTED
}

enum OutboxStatus {
  PENDING
  PROCESSING
  PUBLISHED
  FAILED
}

// ============================================================================
//  IDENTITY
// ============================================================================

model User {
  id           String     @id @default(uuid(7)) @db.Uuid
  email        String?    @unique
  /// O'zbekistonda telefon asosiy identifikator
  phone        String?    @unique
  /// Argon2id. bcrypt EMAS — docs/11-security.md §2
  passwordHash String?    @map("password_hash")
  status       UserStatus @default(PENDING_VERIFICATION)

  emailVerified Boolean @default(false) @map("email_verified")
  phoneVerified Boolean @default(false) @map("phone_verified")

  totpSecret  String?  @map("totp_secret")
  totpEnabled Boolean  @default(false) @map("totp_enabled")

  /// uz-Latn | uz-Cyrl | ru
  locale String @default("uz-Latn")

  lastLoginAt DateTime? @map("last_login_at") @db.Timestamptz(3)
  lastLoginIp String?   @map("last_login_ip")

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(3)

  roles         UserRole[]
  refreshTokens RefreshToken[]
  customer      Customer?
  auditLogs     AuditLog[]
  posShifts     PosShift[]

  @@index([status])
  @@map("users")
}

/// Rol resursga bog'lanishi mumkin: kuryer faqat o'ziga tayinlangan
/// jo'natmani ko'radi. Faqat rolni tekshirish YETARLI EMAS.
/// docs/11-security.md §3
model UserRole {
  id     String @id @default(uuid(7)) @db.Uuid
  userId String @map("user_id") @db.Uuid
  role   Role

  /// NULL = global. Aks holda: WAREHOUSE + scopeType=WAREHOUSE + scopeId=<id>
  scopeType String? @map("scope_type")
  scopeId   String? @map("scope_id") @db.Uuid

  grantedBy String?   @map("granted_by") @db.Uuid
  expiresAt DateTime? @map("expires_at") @db.Timestamptz(3)

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, role, scopeType, scopeId])
  @@index([userId])
  @@map("user_roles")
}

/// Refresh rotation + reuse detection. Ishlatilgan token qayta kelsa →
/// BUTUN oila bekor qilinadi. docs/11-security.md §2
model RefreshToken {
  id        String @id @default(uuid(7)) @db.Uuid
  userId    String @map("user_id") @db.Uuid
  /// SHA-256. Plaintext HECH QACHON saqlanmaydi.
  tokenHash String @unique @map("token_hash")
  familyId  String @map("family_id") @db.Uuid

  usedAt    DateTime? @map("used_at") @db.Timestamptz(3)
  revokedAt DateTime? @map("revoked_at") @db.Timestamptz(3)
  expiresAt DateTime  @map("expires_at") @db.Timestamptz(3)

  userAgent String? @map("user_agent")
  ipAddress String? @map("ip_address")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([familyId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

// ============================================================================
//  CATALOG — docs/05-catalog-and-search.md
// ============================================================================

/// Kategoriya daraxti. Materialized path — o'qish tez, yozish kam.
/// Yoritgich kategoriyalari (Figma footer'idan): Люстры, Споты, Светильники,
/// Трековые светильники, Бра, Уличные светильники, Торшеры, Технические,
/// Комплектующие, Светодиодные ленты, Настольные лампы
model Category {
  id       String  @id @default(uuid(7)) @db.Uuid
  parentId String? @map("parent_id") @db.Uuid

  slug String @unique
  /// Ko'p tilli: { "uz-Latn": "Qandillar", "uz-Cyrl": "...", "ru": "Люстры" }
  name Json
  description Json?

  /// Materialized path: "/lustry/potolochnye/". Ajdodlarni bitta so'rovda topish.
  path  String
  depth Int    @default(0)

  imageUrl String? @map("image_url")
  sortOrder Int    @default(0) @map("sort_order")
  isActive  Boolean @default(true) @map("is_active")

  /// SEO
  metaTitle       Json? @map("meta_title")
  metaDescription Json? @map("meta_description")

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(3)

  parent   Category?  @relation("CategoryTree", fields: [parentId], references: [id], onDelete: Restrict)
  children Category[] @relation("CategoryTree")
  products Product[]

  @@index([parentId])
  @@index([path])
  @@index([slug])
  @@map("categories")
}

/// Atribut ta'rifi. Yoritgichga xos: lyumen, rang harorati, IP, tsokol...
/// docs/05-catalog-and-search.md §2
model Attribute {
  id   String        @id @default(uuid(7)) @db.Uuid
  code String        @unique
  type AttributeType

  /// Ko'p tilli nom
  name Json
  /// Birlik: "lm", "K", "W", "Ra", "°"
  unit String?

  /// Filtrda ko'rinadimi
  isFilterable Boolean @default(true) @map("is_filterable")
  /// Variant hosil qiladimi (rang → ha; lyumen → yo'q)
  isVariantAxis Boolean @default(false) @map("is_variant_axis")
  /// Taqqoslash jadvalida
  isComparable Boolean @default(true) @map("is_comparable")

  sortOrder Int @default(0) @map("sort_order")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  values AttributeValue[]

  @@index([code])
  @@map("attributes")
}

/// ENUM va ORDINAL atributlar uchun ruxsat etilgan qiymatlar.
/// ORDINAL uchun `rank` muhim: IP65 (rank 5) IP44 (rank 3) talabini qoplaydi.
model AttributeValue {
  id          String @id @default(uuid(7)) @db.Uuid
  attributeId String @map("attribute_id") @db.Uuid

  code  String
  /// Ko'p tilli: { "ru": "Тёплый белый", "uz-Latn": "Issiq oq" }
  label Json

  /// ORDINAL uchun tartib. IP20=1, IP44=3, IP54=4, IP65=5, IP67=6
  rank Int?
  /// Rang uchun HEX (rang harorati vizualizatsiyasi: 2700K → #FFB46B)
  hexColor String? @map("hex_color")

  sortOrder Int @default(0) @map("sort_order")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  attribute Attribute @relation(fields: [attributeId], references: [id], onDelete: Cascade)

  @@unique([attributeId, code])
  @@index([attributeId])
  @@map("attribute_values")
}

/// Mahsulot modeli (SKU EMAS). Masalan: "Qandil Aurora".
/// Sotiladigan birlik — ProductVariant.
model Product {
  id         String @id @default(uuid(7)) @db.Uuid
  categoryId String @map("category_id") @db.Uuid

  slug String @unique
  name Json
  description Json?

  brand        String?
  manufacturer String?
  countryOfOrigin String? @map("country_of_origin")

  status ProductStatus @default(DRAFT)

  /// Mo'rt (shisha qandil) — qadoqlash va yetkazib berish uchun.
  /// docs/09-delivery-and-operations.md §3
  isFragile Boolean @default(false) @map("is_fragile")
  /// O'rnatish xizmati taklif qilinadimi (elektrik kerak)
  requiresInstallation Boolean @default(false) @map("requires_installation")

  metaTitle       Json? @map("meta_title")
  metaDescription Json? @map("meta_description")

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(3)

  category Category         @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  variants ProductVariant[]
  media    Media[]
  reviews  Review[]
  questions Question[]

  @@index([categoryId])
  @@index([status])
  @@index([slug])
  @@map("products")
}

/// Sotiladigan birlik (SKU).
///
/// ⚠️ VARIANT MATRITSASI PORTLASHI: 1 qandil × 4 rang × 3 o'lcham × 2 lampa
/// soni = 24 SKU. Faqat MAVJUD kombinatsiyalar saqlanadi, hammasi emas.
/// docs/05-catalog-and-search.md §1
model ProductVariant {
  id        String @id @default(uuid(7)) @db.Uuid
  productId String @map("product_id") @db.Uuid

  sku     String  @unique
  barcode String? @unique

  /// Variant o'qi qiymatlari: { "color": "chrome", "size": "d600", "lamp_count": "6" }
  /// isVariantAxis=true bo'lgan atributlardan.
  axisValues Json @map("axis_values")

  /// ══ YORITGICH ATRIBUTLARI ══
  /// Tez-tez filtrlanadigan atributlar ustun sifatida (tez so'rov).
  /// Qolganlari `attributes` JSONB da (moslashuvchan).
  /// Bu gibrid yondashuv — sof EAV sekin, sof JSONB filtrsiz.
  /// docs/05-catalog-and-search.md §1
  luminousFlux     Int?     @map("luminous_flux")      // lm
  colorTemperature Int?     @map("color_temperature")  // K — brend nomi shundan
  cri              Int?                                 // Ra
  ipRating         String?  @map("ip_rating")          // IP20..IP67
  socketType       String?  @map("socket_type")        // E27, E14, GU10...
  power            Decimal? @db.Decimal(8, 2)          // W
  voltage          Int?                                 // 220, 12, 24
  dimmable         Boolean  @default(false)
  beamAngle        Int?     @map("beam_angle")         // °
  bulbsIncluded    Boolean  @default(false) @map("bulbs_included")
  lightSource      String?  @map("light_source")       // LED, halogen...
  mountType        String?  @map("mount_type")

  /// Qolgan atributlar. GIN index bilan filtrlanadi.
  attributes Json @default("{}")

  /// Fizik
  weightGrams Int? @map("weight_grams")
  lengthMm    Int? @map("length_mm")
  widthMm     Int? @map("width_mm")
  heightMm    Int? @map("height_mm")

  /// Tannarx — foyda hisobi uchun. ⚠️ TIYINDA.
  /// FIFO yoki o'rtacha — docs/10-crm-pos-analytics.md §4
  costPriceAmount BigInt? @map("cost_price_amount")

  isActive Boolean @default(true) @map("is_active")

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(3)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  media        Media[]
  prices       Price[]
  stockItems   StockItem[]
  reservations StockReservation[]
  movements    StockMovement[]
  cartItems    CartItem[]
  orderItems   OrderItem[]
  poItems      PurchaseOrderItem[]

  compatibleWith CompatibilityRule[] @relation("SourceVariant")
  compatibleFrom CompatibilityRule[] @relation("TargetVariant")

  @@index([productId])
  @@index([sku])
  @@index([colorTemperature])
  @@index([ipRating])
  @@index([socketType])
  @@index([attributes], type: Gin)
  @@map("product_variants")
}

/// Trek tizimi mosligi: trek + konnektor + spot bir-biriga mos kelishi kerak.
/// "Bu spot bu trekka mos keladimi?" — compatibility graph.
/// docs/05-catalog-and-search.md §6
model CompatibilityRule {
  id String @id @default(uuid(7)) @db.Uuid

  sourceVariantId String @map("source_variant_id") @db.Uuid
  targetVariantId String @map("target_variant_id") @db.Uuid

  /// COMPATIBLE | REQUIRES | INCOMPATIBLE
  kind String
  note Json?

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  sourceVariant ProductVariant @relation("SourceVariant", fields: [sourceVariantId], references: [id], onDelete: Cascade)
  targetVariant ProductVariant @relation("TargetVariant", fields: [targetVariantId], references: [id], onDelete: Cascade)

  @@unique([sourceVariantId, targetVariantId, kind])
  @@index([sourceVariantId])
  @@index([targetVariantId])
  @@map("compatibility_rules")
}

model Media {
  id        String  @id @default(uuid(7)) @db.Uuid
  productId String? @map("product_id") @db.Uuid
  variantId String? @map("variant_id") @db.Uuid

  /// IMAGE | VIDEO | VIEW_360 | DOCUMENT (datasheet)
  kind String
  url  String
  /// Responsive variantlar: { "webp_400": "...", "webp_800": "..." }
  derivatives Json?

  alt       Json?
  sortOrder Int   @default(0) @map("sort_order")
  isPrimary Boolean @default(false) @map("is_primary")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  product Product?        @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant ProductVariant? @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([variantId])
  @@map("media")
}

// ============================================================================
//  PRICING — Pul: BigInt, TIYINDA
// ============================================================================

model PriceList {
  id   String @id @default(uuid(7)) @db.Uuid
  code String @unique
  name Json

  /// Ustuvorlik: bir necha ro'yxat mos kelsa, yuqorisi g'olib
  priority Int @default(0)

  validFrom DateTime? @map("valid_from") @db.Timestamptz(3)
  validTo   DateTime? @map("valid_to") @db.Timestamptz(3)

  isActive Boolean @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  prices Price[]

  @@map("price_lists")
}

model Price {
  id          String @id @default(uuid(7)) @db.Uuid
  priceListId String @map("price_list_id") @db.Uuid
  variantId   String @map("variant_id") @db.Uuid

  /// ⚠️ TIYINDA. Float HECH QACHON. docs/adr/0003-money-as-bigint-tiyin.md
  amount   BigInt
  currency String @default("UZS")

  /// Chizib tashlangan narx (aksiya ko'rsatish uchun)
  compareAtAmount BigInt? @map("compare_at_amount")

  /// Ulgurji: shu miqdordan boshlab
  minQuantity Int @default(1) @map("min_quantity")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  priceList PriceList      @relation(fields: [priceListId], references: [id], onDelete: Cascade)
  variant   ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@unique([priceListId, variantId, minQuantity])
  @@index([variantId])
  @@map("prices")
}

/// Chegirma/aksiya. ⚠️ Qo'llash tartibi DETERMINISTIK bo'lishi shart:
/// bir xil savat → bir xil narx. docs/07-order-and-checkout.md §7
model Discount {
  id   String @id @default(uuid(7)) @db.Uuid
  code String? @unique
  name Json

  /// PERCENTAGE | FIXED_AMOUNT | FREE_SHIPPING | BUY_X_GET_Y
  kind String

  /// PERCENTAGE uchun basis point (250 = 2.5%). FIXED uchun tiyin.
  value BigInt

  /// Qo'llash shartlari: { "minSubtotal": 5000000, "categoryIds": [...] }
  conditions Json @default("{}")

  /// Baholash tartibi — determinizm uchun KRITIK
  priority Int @default(0)
  /// Boshqa chegirma bilan birga qo'llanadimi
  isStackable Boolean @default(false) @map("is_stackable")

  usageLimit      Int? @map("usage_limit")
  usageCount      Int  @default(0) @map("usage_count")
  perCustomerLimit Int? @map("per_customer_limit")

  validFrom DateTime? @map("valid_from") @db.Timestamptz(3)
  validTo   DateTime? @map("valid_to") @db.Timestamptz(3)
  isActive  Boolean   @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  @@index([code])
  @@index([isActive, priority])
  @@map("discounts")
}

// ============================================================================
//  CUSTOMER / CRM
// ============================================================================

model Customer {
  id     String  @id @default(uuid(7)) @db.Uuid
  userId String? @unique @map("user_id") @db.Uuid

  firstName String? @map("first_name")
  lastName  String? @map("last_name")
  /// Mehmon buyurtmasi telefon bo'yicha bog'lanadi
  phone     String
  email     String?

  /// B2B: dizayner, qurilish brigadasi
  isBusiness  Boolean @default(false) @map("is_business")
  companyName String? @map("company_name")
  taxId       String? @map("tax_id")

  /// RFM — docs/10-crm-pos-analytics.md §1
  totalOrders      Int     @default(0) @map("total_orders")
  totalSpentAmount BigInt  @default(0) @map("total_spent_amount")
  lastOrderAt      DateTime? @map("last_order_at") @db.Timestamptz(3)
  rfmSegment       String? @map("rfm_segment")

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(3)

  user      User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  addresses Address[]
  orders    Order[]
  carts     Cart[]
  leads     Lead[]
  reviews   Review[]
  questions Question[]

  @@index([phone])
  @@index([rfmSegment])
  @@map("customers")
}

model Address {
  id         String @id @default(uuid(7)) @db.Uuid
  customerId String @map("customer_id") @db.Uuid

  /// Toshkent shahri / viloyat
  region   String
  district String?
  city     String
  street   String
  building String?
  apartment String?
  /// Kvartira qavati — qandil ko'tarish uchun muhim (lift bormi?)
  floor    Int?
  hasElevator Boolean? @map("has_elevator")

  postalCode String? @map("postal_code")
  note       String?

  latitude  Decimal? @db.Decimal(9, 6)
  longitude Decimal? @db.Decimal(9, 6)

  isDefault Boolean @default(false) @map("is_default")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  customer  Customer   @relation(fields: [customerId], references: [id], onDelete: Cascade)
  shipments Shipment[]

  @@index([customerId])
  @@map("addresses")
}

model Lead {
  id         String  @id @default(uuid(7)) @db.Uuid
  customerId String? @map("customer_id") @db.Uuid

  name  String?
  phone String
  /// WEBSITE_FORM | PHONE | TELEGRAM | WALK_IN | INSTAGRAM
  source String
  status LeadStatus @default(NEW)

  note       String?
  assignedTo String? @map("assigned_to") @db.Uuid


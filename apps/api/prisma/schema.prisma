/// ⚠️ SNAPSHOT. Narx, nom, atribut — hammasi buyurtma paytida NUSXALANADI.
/// Product/Price dan o'qilmaydi.
///
/// Sabab: mahsulot narxi ertaga o'zgarsa yoki mahsulot o'chirilsa, eski
/// buyurtma buzilmasligi kerak. Bu ko'p loyihada qilinadigan xato.
/// docs/07-order-and-checkout.md §5
model OrderItem {
  id        String @id @default(uuid(7)) @db.Uuid
